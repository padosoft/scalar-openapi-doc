{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-tree:*)",
      "Bash(git merge-base:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(gh release:*)",
      "Bash(gh auth status:*)",
      "Bash(composer:*)",
      "Bash(php artisan:*)",
      "Bash(php -v:*)",
      "Bash(vendor/bin/pint:*)",
      "Bash(vendor/bin/phpstan:*)",
      "Bash(vendor/bin/pest:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npx playwright:*)",
      "Bash(copilot:*)",
      "PowerShell(git status:*)",
      "PowerShell(git diff:*)",
      "PowerShell(git log:*)",
      "PowerShell(git add:*)",
      "PowerShell(git commit:*)",
      "PowerShell(git checkout:*)",
      "PowerShell(git switch:*)",
      "PowerShell(git branch:*)",
      "PowerShell(git fetch:*)",
      "PowerShell(git pull:*)",
      "PowerShell(git push:*)",
      "PowerShell(git merge:*)",
      "PowerShell(git rev-parse:*)",
      "PowerShell(git ls-tree:*)",
      "PowerShell(git merge-base:*)",
      "PowerShell(gh pr:*)",
      "PowerShell(gh api:*)",
      "PowerShell(gh run:*)",
      "PowerShell(gh release:*)",
      "PowerShell(gh auth status:*)",
      "PowerShell(composer:*)",
      "PowerShell(php artisan:*)",
      "PowerShell(php -v:*)",
      "PowerShell(vendor/bin/pint:*)",
      "PowerShell(vendor/bin/phpstan:*)",
      "PowerShell(vendor/bin/pest:*)",
      "PowerShell(npm run:*)",
      "PowerShell(npm install:*)",
      "PowerShell(npm ci:*)",
      "PowerShell(npx playwright:*)",
      "PowerShell(copilot:*)"
    ],
    "deny": [
      "Bash(git push*--force*)",
      "Bash(git push* -f*)",
      "Bash(git push* +*)",
      "Bash(git reset --hard:*)",
      "PowerShell(git push*--force*)",
      "PowerShell(git push* -f*)",
      "PowerShell(git push* +*)",
      "PowerShell(git reset --hard:*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Read(./.env.development)",
      "Read(./.env.testing)",
      "Read(./.env.staging)",
      "Read(./.env.production)",
      "Read(./.env.backup)",
      "Read(./.env.bak)"
    ]
  }
}
